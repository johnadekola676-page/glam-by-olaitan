{
  "mcpServers": {
    "github": {
      "github": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-github"],
        "env": {
          "GITHUB_PERSONAL_ACCESS_TOKEN": "REPLACE_WITH_YOUR_GITHUB_PAT"
        }
      },
      "notion": {
        "command": "npx",
        "args": ["-y", "@notionhq/mcp"],
        "env": {
          "NOTION_API_KEY": "REPLACE_WITH_YOUR_NOTION_INTEGRATION_TOKEN"
        }
      },
      ...
      "neon": {
        "command": "npx",
        "args": ["-y", "@neondatabase/mcp-server-neon"],
        "env": {
          "NEON_API_KEY": "REPLACE_WITH_YOUR_NEON_API_KEY"
        }
      },
      "obsidian": {
        "command": "npx",
        "args": ["@bitbonsai/mcpvault@latest", "C:\\Users\\HP\\AgentVault"],
        "env": {}
      },
      "browser": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-playwright"],
        "env": {}
      },
      "cloudflare": {
        "command": "npx",
        "args": ["-y", "@cloudflare/mcp-server-cloudflare"],
        "env": {
          "CLOUDFLARE_API_TOKEN": "REPLACE_WITH_YOUR_CLOUDFLARE_API_TOKEN",
          "CLOUDFLARE_ACCOUNT_ID": "REPLACE_WITH_YOUR_CLOUDFLARE_ACCOUNT_ID"
        }
      }

      }
    }
    }
    }
